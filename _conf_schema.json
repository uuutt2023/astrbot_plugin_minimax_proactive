{
    "enable_proactive_chat": {
        "name": "开启主动对话",
        "description": "是否启用主动对话功能。关闭后机器人不会主动发起对话",
        "type": "bool",
        "default": true
    },
    "enable_reminder": {
        "name": "开启提醒功能",
        "description": "是否启用提醒功能，包括LLM工具和指令(/mpro add等)",
        "type": "bool",
        "default": true
    },
    "debug_mode": {
        "name": "调试模式",
        "description": "启用详细日志输出，方便排查问题",
        "type": "bool",
        "default": false
    },
    "use_astrbot_provider": {
        "name": "选择 LLM 提供商",
        "description": "选择使用的模型提供商",
        "type": "string",
        "_special": "select_provider"
    },
    "minimax_api_key": {
        "name": "MiniMax API Key",
        "description": "MiniMax API密钥，在MiniMax开放平台获取",
        "type": "string",
        "default": ""
    },
    "minimax_base_url": {
        "name": "API 地址",
        "description": "MiniMax API接口地址",
        "type": "string",
        "default": "https://api.minimax.chat/v1"
    },
    "minimax_model": {
        "name": "模型名称",
        "description": "使用的模型名称",
        "type": "string",
        "default": "abab6.5s-chat"
    },
    "minimax_temperature": {
        "name": "Temperature",
        "description": "生成随机性，0-1之间，值越大越随机",
        "type": "float",
        "default": 0.7
    },
    "minimax_max_tokens": {
        "name": "最大 Token 数",
        "description": "最大生成Token数",
        "type": "int",
        "default": 4096
    },
    "private_enable": {
        "name": "启用私聊主动对话",
        "description": "是否启用私聊主动对话功能",
        "type": "bool",
        "default": false
    },
    "private_prompt": {
        "name": "主动对话提示词",
        "description": "触发主动对话时的提示词。支持 {{unanswered_count}}（未回复次数）和 {{current_time}}（当前时间）变量。提示词从 prompts/private_proactive.txt 文件读取",
        "type": "text",
        "default": ""
    },
    "private_use_minimax": {
        "name": "使用 MiniMax 回复",
        "description": "用 MiniMax API 替换默认对话模型，所有私聊消息都使用 MiniMax 回复",
        "type": "bool",
        "default": false
    },
    "private_read_air": {
        "name": "启用读空气",
        "description": "使用 LLM 判断是否需要回复，减少不必要的回复",
        "type": "bool",
        "default": false
    },
    "private_read_air_provider": {
        "name": "读空气模型",
        "description": "选择读空气功能使用的模型提供商",
        "type": "string",
        "_special": "select_provider"
    },
    "private_read_air_prompt": {
        "name": "读空气提示词",
        "description": "判断是否需要回复的提示词。提示词从 prompts/read_air.txt 文件读取",
        "type": "text",
        "default": ""
    },
    "private_emoji_gate": {
        "name": "表情包守门员",
        "description": "对单独发表情包进行概率性放行，减少刷屏",
        "type": "bool",
        "default": false
    },
    "private_emoji_gate_rate": {
        "name": "表情包放行概率",
        "description": "表情包守门员放行概率（0-100），50表示50%概率放行",
        "type": "int",
        "default": 30
    },
    "private_min_interval": {
        "name": "最小触发间隔（分钟）",
        "description": "两次主动对话之间的最小时间间隔",
        "type": "int",
        "default": 30
    },
    "private_max_interval": {
        "name": "最大触发间隔（分钟）",
        "description": "两次主动对话之间的最大时间间隔",
        "type": "int",
        "default": 900
    },
    "private_max_times": {
        "name": "最大主动次数",
        "description": "连续未回复时最多主动对话的次数，0表示不限制",
        "type": "int",
        "default": 3
    },
    "private_quiet_hours": {
        "name": "免打扰时段",
        "description": "不主动发起对话的时间段。格式: 1-7表示每天凌晨1点到早上7点，22-6表示22点到次日6点",
        "type": "string",
        "default": "1-7"
    },
    "private_auto_trigger": {
        "name": "启用自动触发",
        "description": "机器人启动后首次收到消息时自动触发对话",
        "type": "bool",
        "default": false
    },
    "private_auto_delay": {
        "name": "首次触发延迟（分钟）",
        "description": "机器人启动后等待多少分钟再首次触发",
        "type": "int",
        "default": 5
    },
    "private_tts": {
        "name": "启用 TTS 语音",
        "description": "将回复转换为语音发送",
        "type": "bool",
        "default": false
    },
    "private_tts_with_text": {
        "name": "TTS 同时发送文本",
        "description": "发送语音时是否同时发送原文文本",
        "type": "bool",
        "default": true
    },
    "private_t2i": {
        "name": "启用文转图",
        "description": "将长消息转换为图片发送",
        "type": "bool",
        "default": false
    },
    "private_t2i_threshold": {
        "name": "文转图触发阈值",
        "description": "超过此字符数时转换为图片发送",
        "type": "int",
        "default": 500
    },
    "private_image_desc": {
        "name": "启用表情包转述",
        "description": "使用 LLM 描述消息中的表情包/图片内容，让对话更自然",
        "type": "bool",
        "default": false
    },
    "private_image_desc_provider": {
        "name": "表情包转述模型",
        "description": "选择表情包转述使用的模型提供商",
        "type": "string",
        "_special": "select_provider"
    },
    "private_image_desc_prompt": {
        "name": "表情包转述提示词",
        "description": "描述表情包/图片内容的提示词。提示词从 prompts/image_desc.txt 文件读取",
        "type": "text",
        "default": ""
    },
    "group_enable": {
